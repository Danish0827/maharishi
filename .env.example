# ─────────────────────────────────────────────────────────────
# Contact form email delivery (SMTP via Nodemailer)
# Copy this file to ".env.local" and fill in real values.
# The form on the site sends submissions to CONTACT_TO_EMAIL.
# ─────────────────────────────────────────────────────────────

# Where form submissions are delivered
CONTACT_TO_EMAIL=danish@healthus.ai

# The "from" address shown on the email (should match your SMTP account/domain)
CONTACT_FROM_EMAIL=website@healthus.ai

# ---- SMTP server settings ----
# Example for Gmail: host=smtp.gmail.com, port=465, secure=true,
#   user=your@gmail.com, pass=<16-char Google App Password>
# Example for a custom domain (healthus.ai) mailbox: ask your host for SMTP details.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
