# ─────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in real values.
# ─────────────────────────────────────────────────────────────

# ── Docfyn Push Lead API (CRM) ───────────────────────────────
# Leads submitted on the site are pushed into the Docfyn CRM.
# Credentials are issued by the Docfyn integration team.
DOCFYN_API_URL=https://crm-api.docfyn.com/api/v1/external/leads
DOCFYN_MERCHANT=third_party_paid_marketing
DOCFYN_API_KEY=your-secret-api-key
DOCFYN_ACCOUNT_ID=your-account-id
# Branch/location code for this landing page
DOCFYN_LOCATION=epsjkrp

# ── Email notification (backup + instant visibility) ─────────
# Every lead is ALSO emailed to this comma-separated list.
CONTACT_TO_EMAIL=danish@healthus.ai,healthusads@gmail.com
CONTACT_FROM_EMAIL=danish@healthus.ai

# SMTP (Gmail example: create an App Password for SMTP_PASS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
